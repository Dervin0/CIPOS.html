    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800;900&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        bgBase: '#000000',
                        panel: '#0A0A0A',
                        panelHover: '#111111',
                        goldAccent: '#D4AF37',
                        cyan: '#00F0FF'
                    },
                    animation: {
                        'latido': 'latido 1.5s ease-in-out infinite',
                    },
                    keyframes: {
                        latido: {
                            '0%, 100%': { transform: 'scale(1)', boxShadow: '0 0 30px rgba(212,175,55,0.3)' },
                            '50%': { transform: 'scale(1.05)', boxShadow: '0 0 60px rgba(212,175,55,0.7)' },
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #000000;
            color: #ffffff;
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
            user-select: none;
            scroll-behavior: smooth;
        }

        .bento-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1rem;
            padding: 1rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .bento-card {
            background-color: #0A0A0A;
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 24px;
            padding: 2rem;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .bento-card:hover {
            background-color: #111111;
            border-color: rgba(212, 175, 55, 0.3);
            transform: translateY(-2px);
            box-shadow: 0 10px 40px -10px rgba(0,0,0,0.5);
        }

        .app-view {
            display: none;
            animation: fadeIn 0.4s ease;
        }
        .app-view.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .glass-panel {
            background: linear-gradient(145deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
            border: 1px solid rgba(212, 175, 55, 0.15);
        }

        .gold-gradient {
            background: linear-gradient(to right, #F6E27A, #D4AF37, #AA8222);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .btn-gold {
            background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
            color: #050B14;
            font-weight: 900;
            transition: all 0.3s ease;
        }
        .btn-gold:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(212, 175, 55, 0.4);
        }

        .rvoe-badge {
            background: #D4AF37;
            color: #000;
            padding: 0.5rem 1.5rem;
            border-radius: 8px;
            font-weight: 900;
            letter-spacing: 0.1em;
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.8);
            animation: pulse-glow 2s infinite;
            display: inline-block;
            font-size: 1.1rem;
        }

        @keyframes pulse-glow {
            0% { box-shadow: 0 0 15px rgba(212, 175, 55, 0.6); }
            50% { box-shadow: 0 0 35px rgba(212, 175, 55, 1); }
            100% { box-shadow: 0 0 15px rgba(212, 175, 55, 0.6); }
        }

        .cuatri-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
        }
    </style>
</head>
